---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="nav-logo" style="font-size:16px;">
          <div class="nav-logo-mark">NS</div>
          <span>nano synapsys</span>
        </a>
        <p class="footer-brand-desc">
          A product studio at the intersection of AI and real-world impact.
          Building intelligence. Shipping products.
        </p>
      </div>

      <!-- Products -->
      <div>
        <p class="footer-col-title">Products</p>
        <ul class="footer-links">
          <li><a href="https://www.nanoplasticity.com" target="_blank" rel="noopener">Nanoplasticity</a></li>
          <li><a href="https://www.ai-evolution.com.au" target="_blank" rel="noopener">AI Evolution</a></li>
          <li><a href="/#products">KickWiz</a></li>
          <li><a href="/#products" style="color:var(--text-dim);">More coming soon</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="footer-col-title">Company</p>
        <ul class="footer-links">
          <li><a href="/#about">About</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
      </div>

      <!-- KickWiz Legal -->
      <div>
        <p class="footer-col-title">KickWiz</p>
        <ul class="footer-links">
          <li><a href="/kickwiz/privacy">Privacy Policy</a></li>
          <li><a href="/kickwiz/terms">Terms &amp; Conditions</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {year} Nano Synapsys. All rights reserved.</span>
      <div class="footer-social">
        <!-- LinkedIn — replace href when profile is ready -->
        <a
          href="#"
          aria-label="LinkedIn (coming soon)"
          class="social-icon"
          title="LinkedIn — coming soon"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
