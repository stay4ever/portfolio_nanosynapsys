---
import Base from './Base.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    author: string;
    tags: string[];
  };
}

const { frontmatter } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date(frontmatter.date));
---

<Base title={`${frontmatter.title} — Nano Synapsys`} description={frontmatter.description}>
  <section class="blog-post-hero">
    <div class="container">
      <a href="/blog" class="section-tag" style="margin-bottom:24px;display:inline-flex;">← Blog</a>
      <div class="blog-tags" style="display:flex;gap:8px;margin-bottom:20px;">
        {frontmatter.tags.map(tag => (
          <span class="product-badge live">{tag}</span>
        ))}
      </div>
      <h1 style="font-size:clamp(32px,5vw,58px);max-width:820px;margin-bottom:24px;">{frontmatter.title}</h1>
      <p style="font-size:17px;color:var(--text-muted);max-width:600px;line-height:1.75;margin-bottom:32px;">{frontmatter.description}</p>
      <div style="display:flex;align-items:center;gap:16px;font-size:14px;color:var(--text-dim);">
        <span>{frontmatter.author}</span>
        <span style="width:4px;height:4px;border-radius:50%;background:currentColor;"></span>
        <span>{formattedDate}</span>
      </div>
    </div>
  </section>

  <div class="container">
    <article class="blog-post-body">
      <slot />
    </article>
  </div>
</Base>
